# TilPaid Frontend Environment Variables
# Copy to .env.local and fill in values

# API URL — your Railway backend
VITE_API_URL=https://tilpaid-api-production.up.railway.app

# Apple Sign In (for Capacitor/native)
# VITE_APPLE_CLIENT_ID=com.midlinedigital.tilpaid

# Google Sign In
# VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
